# Ark — Environment Variables
# Copy this to .env and fill in the values you need.
# You only need credentials for the providers you use.

# Anthropic (Claude)
ANTHROPIC_API_KEY=

# OpenAI
OPENAI_API_KEY=

# Google (Gemini)
GOOGLE_AI_API_KEY=

# Ollama (local — no key needed, just the URL)
# OLLAMA_URL=http://localhost:11434

# Supabase (only if using Supabase persistence)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=
